{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "baseUrl": "src",
    "paths": {
      "@config/*": ["config/*"],
      "@common/*": ["common/*"],
      "@ems/*": ["modules/ems/*"],
      "@pms/*": ["modules/pms/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}


